datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String?
  role      String    @default("USER")
  bookings  Booking[]
  createdAt DateTime  @default(now())
}

model Booking {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime
  startTime   Int
  duration    Int
  totalPrice  Float
  status      String   @default("PENDING")
  notes       String?
  createdAt   DateTime @default(now())
}

model Availability {
  id        String   @id @default(uuid())
  dayOfWeek Int
  startTime Int
  endTime   Int
}
